<?xml version="1.0" encoding="utf-8"?>
<!-- Expanded pane of the monitoring notification: header row, tower address,
     signal-strength bar, and a two-column stat grid. Four pre-tinted progress
     bars are toggled by visibility because RemoteViews can't retint one at
     runtime below API 31. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:paddingTop="4dp"
    android:paddingBottom="4dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/notif_carrier"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/notif_text_primary"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/notif_tech"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:paddingStart="6dp"
            android:paddingEnd="6dp"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:background="@drawable/bg_chip_5g"
            android:maxLines="1" />

        <TextView
            android:id="@+id/notif_rsrp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/notif_text_primary"
            android:maxLines="1" />
    </LinearLayout>

    <TextView
        android:id="@+id/notif_address"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="12sp"
        android:textColor="@color/notif_text_secondary"
        android:maxLines="2"
        android:ellipsize="end" />

    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp">

        <ProgressBar
            android:id="@+id/notif_bar_excellent"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progressTint="#4CAF50"
            android:progressBackgroundTint="@color/notif_bar_bg"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/notif_bar_good"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progressTint="#8BC34A"
            android:progressBackgroundTint="@color/notif_bar_bg"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/notif_bar_fair"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progressTint="#FFB74D"
            android:progressBackgroundTint="@color/notif_bar_bg"
            android:visibility="gone" />

        <ProgressBar
            android:id="@+id/notif_bar_poor"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="6dp"
            android:max="100"
            android:progressTint="#E57373"
            android:progressBackgroundTint="@color/notif_bar_bg"
            android:visibility="gone" />
    </FrameLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:orientation="horizontal">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_label_band"
                android:textSize="10sp"
                android:textColor="@color/notif_text_muted" />

            <TextView
                android:id="@+id/notif_band"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/notif_text_primary"
                android:maxLines="1"
                android:ellipsize="end" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_label_cell_id"
                android:textSize="10sp"
                android:textColor="@color/notif_text_muted" />

            <TextView
                android:id="@+id/notif_cellid"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/notif_text_primary"
                android:maxLines="1" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_label_pci_tac"
                android:textSize="10sp"
                android:textColor="@color/notif_text_muted" />

            <TextView
                android:id="@+id/notif_pcitac"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="6dp"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/notif_text_primary"
                android:maxLines="1" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/notif_label_ca"
                android:textSize="10sp"
                android:textColor="@color/notif_text_muted" />

            <TextView
                android:id="@+id/notif_ca"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/notif_text_primary"
                android:maxLines="1" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
